#!/bin/sh
# Block commits to main if package.json version is already tagged.

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH" != "main" ]; then
  exit 0
fi

VERSION="v$(node -p "require('./package.json').version" 2>/dev/null)"
if git rev-parse "$VERSION" >/dev/null 2>&1; then
  echo ""
  echo "❌ Commit blocked: tag $VERSION already exists."
  echo "   Bump the version in package.json before committing to main."
  echo ""
  exit 1
fi

echo "✅ Version $VERSION is new — committing."
exit 0
